# ============================================================================
# MeritCoin — Variables de entorno
# Copia este archivo:  cp .env.example .env
# ============================================================================

# ── Moodle ──────────────────────────────────────────────────────────────────
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=Admin1234!
MOODLE_ADMIN_EMAIL=admin@meritcoin.local
MOODLE_PORT=8080
MOODLE_HTTPS_PORT=8443

# ── MariaDB (Moodle) ───────────────────────────────────────────────────────
MOODLE_DB_USER=bn_moodle
MOODLE_DB_PASSWORD=moodle_pass
MOODLE_DB_NAME=bitnami_moodle
MARIADB_ROOT_PASSWORD=root_pass

# ── PostgreSQL (Backend FastAPI) ───────────────────────────────────────────
PG_USER=meritcoin
PG_PASSWORD=meritcoin_pass
PG_DB=meritcoin_db
PG_PORT=5432
DATABASE_URL=postgresql+asyncpg://meritcoin:meritcoin_pass@localhost:5432/meritcoin_db

# ── FastAPI Backend ────────────────────────────────────────────────────────
FASTAPI_PORT=8000
HMAC_SECRET=cambia-este-secreto-en-produccion
DEBUG=true

# ── Blockchain (Hardhat) ──────────────────────────────────────────────────
# Hardhat local node por defecto expone en http://127.0.0.1:8545
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# Primera cuenta de Hardhat (solo para desarrollo)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Contratos (se llenan tras desplegar) ──────────────────────────────────
BADGE_CONTRACT_ADDRESS=
MRT_CONTRACT_ADDRESS=
